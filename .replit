modules = ["python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "app:app"]

[workflows]
runButton = "Start Flask"

[[workflows.workflow]]
name = "Start Flask"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill gunicorn || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reload --access-logfile - --error-logfile - app:app"

[[ports]]
localPort = 5000
externalPort = 80