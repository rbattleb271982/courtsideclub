modules = ["python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "app:app"]

[workflows]
runButton = "Test Export"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port --reload main:app"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Flask"
author = 41157766
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill python3 || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 main.py"

[[workflows.workflow]]
name = "Flask Dev"
author = 41157766
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill python3 || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -u main.py"

[[workflows.workflow]]
name = "Flask Debug"
author = 41157766
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill python3 || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_DEBUG=1 python3 -u main.py"

[[workflows.workflow]]
name = "Flask Run"
author = 41157766
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill python3 || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_APP=app.py FLASK_ENV=development flask run --host=0.0.0.0 --port=5000"

[[workflows.workflow]]
name = "Flask Debug Mode"
author = 41157766
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f gunicorn || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_DEBUG=1 python3 -u main.py"

[[workflows.workflow]]
name = "Test Export"
author = 41157766
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill python3 || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_DEBUG=1 python3 -u main.py"

[[ports]]
localPort = 5000
externalPort = 80
